  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6b5a80", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#ffd866" }
    },
    {
      "name": "String Regex",
      "scope": ["string.regexp", "constant.regexp"],
      "settings": { "foreground": "#ff3d71" }
    },
    {
      "name": "String escape / special",
      "scope": ["constant.character.escape", "string.regexp constant.character"],
      "settings": { "foreground": "#7fefff" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#ff6e4a" }
    },
    {
      "name": "Boolean / null / undefined",
      "scope": ["constant.language"],
      "settings": { "foreground": "#ffe14d" }
    },
    {
      "name": "Constant",
      "scope": ["constant", "constant.other"],
      "settings": { "foreground": "#ffe14d" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.other"],
      "settings": { "foreground": "#df78ff" }
    },
    {
      "name": "Control flow keyword",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.trycatch"
      ],
      "settings": { "foreground": "#df78ff", "fontStyle": "bold" }
    },
    {
      "name": "Import / export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": { "foreground": "#a6ff4d" }
    },
    {
      "name": "Storage type (function/class/const/let/var)",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#df78ff" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#7fefff" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "meta.brace"
      ],
      "settings": { "foreground": "#7fefff" }
    },
    {
      "name": "Function name",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "meta.function-call.generic entity.name.function",
        "support.function"
      ],
      "settings": { "foreground": "#00ffcc" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#19ffff" }
    },
    {
      "name": "Variable — local / parameter",
      "scope": ["variable.parameter", "variable.other.local"],
      "settings": { "foreground": "#ff6b9d" }
    },
    {
      "name": "Variable — language (this/self/super)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#df78ff", "fontStyle": "italic" }
    },
    {
      "name": "Object property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.property-name",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#69b4ff" }
    },
    {
      "name": "Type / Class / Interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#ffe14d" }
    },
    {
      "name": "Type parameter / generic",
      "scope": ["entity.name.type.parameter"],
      "settings": { "foreground": "#ffe14d", "fontStyle": "italic" }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#c9a84c" }
    },
    {
      "name": "Namespace / module",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#e5cd84" }
    },
    {
      "name": "Enum member",
      "scope": ["variable.other.enummember"],
      "settings": { "foreground": "#ff6e4a" }
    },
    {
      "name": "Builtin / support",
      "scope": [
        "support.function.builtin",
        "support.variable",
        "support.constant"
      ],
      "settings": { "foreground": "#69b4ff" }
    },
    {
      "name": "Preprocessor / macro",
      "scope": ["keyword.control.directive", "entity.name.function.preprocessor", "meta.preprocessor"],
      "settings": { "foreground": "#a6ff4d" }
    },
    {
      "name": "HTML/JSX tag name",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#ff79c6" }
    },
    {
      "name": "HTML/JSX attribute name",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#a6ff4d" }
    },
    {
      "name": "HTML/JSX attribute value",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": { "foreground": "#ffd866" }
    },
    {
      "name": "CSS property name",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css",
        "meta.property-name.css"
      ],
      "settings": { "foreground": "#69b4ff" }
    },
    {
      "name": "CSS selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#a6ff4d" }
    },
    {
      "name": "CSS unit / value",
      "scope": ["keyword.other.unit.css", "constant.numeric.css"],
      "settings": { "foreground": "#ff6e4a" }
    },
    {
      "name": "CSS color",
      "scope": ["constant.other.color.rgb-value.css", "constant.other.color"],
      "settings": { "foreground": "#ff6e4a" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#0baaba" }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#df78ff", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code",
      "scope": ["markup.inline.raw", "markup.raw.inline"],
      "settings": { "foreground": "#ffd866" }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link", "string.other.link.title.markdown"],
      "settings": { "foreground": "#0baaba" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#6b5a80", "fontStyle": "italic" }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#00ffcc" }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#ff3d71" }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#f4a61a" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#ff3d71", "fontStyle": "underline" }
    }
  ],

  "semanticTokenColors": {
    "comment":              { "foreground": "#6b5a80", "italic": true },
    "keyword":              { "foreground": "#df78ff" },
    "string":               { "foreground": "#ffd866" },
    "number":               { "foreground": "#ff6e4a" },
    "regexp":               { "foreground": "#ff3d71" },
    "operator":             { "foreground": "#7fefff" },
    "function":             { "foreground": "#00ffcc" },
    "function.declaration": { "foreground": "#00ffcc" },
    "method":               { "foreground": "#00ffcc" },
    "method.declaration":   { "foreground": "#00ffcc" },
    "variable":             { "foreground": "#19ffff" },
    "variable.readonly":    { "foreground": "#ffe14d" },
    "parameter":            { "foreground": "#ff6b9d" },
    "property":             { "foreground": "#69b4ff" },
