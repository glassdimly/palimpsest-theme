    "enumMember":           { "foreground": "#ff6e4a" },
    "event":                { "foreground": "#ff6b9d" },
    "class":                { "foreground": "#ffe14d" },
    "interface":            { "foreground": "#ffe14d", "italic": true },
    "enum":                 { "foreground": "#ffe14d" },
    "type":                 { "foreground": "#ffe14d" },
