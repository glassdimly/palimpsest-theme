    "namespace":            { "foreground": "#e5cd84" },
    "module":               { "foreground": "#e5cd84" },
    "struct":               { "foreground": "#ffe14d" },
    "decorator":            { "foreground": "#c9a84c" },
    "label":                { "foreground": "#6b5a80" },
